@model List<App.Core.Application.ViewModels.Grade.GradeViewModel>
@{
    ViewData["Title"] = "Grados";
    ViewData["BannerDescription"] = "Organización de grados y profesores asignados.";
    Layout = "_LayoutCoordinator";
}

<section class="workspace-controls">
    <div class="search-container">
        <input type="text" class="table-search-input" id="searchGradesInput" placeholder="🔍  Buscar grados o profesores..." oninput="filterGrades()" />
    </div>
</section>

<section class="cards-grid" id="gradesGrid">
    @if (Model == null || !Model.Any())
    {
        <div style="grid-column: 1 / -1; text-align: center; color: var(--color-text-muted); padding: 60px; background: #ffffff; border-radius: 16px; border: 1px solid var(--color-border);">
            No se encontraron grados registrados.
        </div>
    }
    else
    {
        @foreach (var grade in Model)
        {
            <div class="grade-card" data-name="@(grade.Name.ToLower() + " " + (grade.TeacherName ?? "").ToLower())">
                <div class="grade-status-dot"></div>
                <h3 class="grade-title">@grade.Name</h3>
                <span class="grade-teacher">Docente: @(string.IsNullOrWhiteSpace(grade.TeacherName) ? "No asignado" : $"Prof. {grade.TeacherName}")</span>
                <div class="grade-divider"></div>
                
                <div style="display: flex; align-items: center; justify-content: space-between; margin-top: auto;">
                    <div class="student-count-pill">@grade.StudentCount Alumnos</div>
                    
                    <a asp-controller="Grade" asp-action="Edit" asp-route-id="@grade.Id" class="btn-action-icon" title="Editar">
                        <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                    </a>
                </div>
            </div>
        }
    }
</section>

@section Scripts {
    <script>
        function filterGrades() {
            const query = document.getElementById('searchGradesInput').value.toLowerCase().trim();
            const cards = document.getElementsByClassName('grade-card');
            for (let card of cards) {
                const name = card.getAttribute('data-name') || '';
                card.style.display = name.includes(query) ? '' : 'none';
            }
        }
    </script>
}