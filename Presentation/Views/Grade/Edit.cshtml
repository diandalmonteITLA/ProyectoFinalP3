@model App.Core.Application.ViewModels.Grade.EditGradeViewModel
@{
    Layout = "_LayoutCoordinator";
    ViewData["Title"] = "Editar Grado";
    ViewData["BannerDescription"] = "Organización de grados y profesores asignados.";
}

<div id="background-grid-container"></div>

<a asp-controller="Grade" asp-action="Index" class="drawer-backdrop" id="createBackdrop" onclick="closeCreateDrawer(event)"></a>

<div class="drawer-form-panel" id="createDrawer">
    <div class="drawer-header">
        <h2 class="drawer-title" id="drawerTitle">Editar Curso - @Model.Grade.Name</h2>
    </div>

    <form asp-controller="Grade" asp-action="Edit" method="post" id="drawerForm" class="drawer-form">
        <input type="hidden" asp-for="Grade.Id" id="field-id" />

        <div class="drawer-body">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="text-danger" style="margin-bottom: 20px; font-size: 13px; font-weight: 500;"></div>
            }

            <div class="drawer-field-group">
                <label class="drawer-label">Docente Encargado</label>
                <select asp-for="Grade.TeacherId" class="drawer-input" id="field-teacher" required>
                    <option value="">Seleccionar docente...</option>
                    @foreach (var teacher in Model.ActiveTeachers)
                    {
                        <option value="@teacher.Id">@teacher.FullName</option>
                    }
                </select>
                <span asp-validation-for="Grade.TeacherId" class="text-danger"></span>
            </div>
        </div>

        <div class="drawer-footer">
            <a asp-controller="Grade" asp-action="Index" class="btn-drawer-cancel btn-drawer-cancel-link" onclick="closeCreateDrawer(event)">Cancelar</a>
            <button type="submit" class="btn-drawer-submit" id="btnDrawerSubmit">Guardar</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeCreateDrawer(event) {
            event.preventDefault();
            const url = event.currentTarget.getAttribute('href') || '/Grade';
            document.getElementById('createBackdrop').classList.remove('open');
            document.getElementById('createDrawer').classList.remove('open');
            setTimeout(() => {
                window.location.href = url;
            }, 300);
        }

        document.addEventListener('DOMContentLoaded', () => {
            fetch('/Grade')
                .then(response => response.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const grid = doc.querySelector('.cards-grid');
                    const controls = doc.querySelector('.workspace-controls');
                    const container = document.getElementById('background-grid-container');
                    
                    if (controls) {
                        const controlsClone = controls.cloneNode(true);
                        const inputs = controlsClone.querySelectorAll('input, select, button, a');
                        inputs.forEach(i => i.setAttribute('disabled', 'disabled'));
                        container.appendChild(controlsClone);
                    }
                    if (grid) {
                        const gridClone = grid.cloneNode(true);
                        const buttons = gridClone.querySelectorAll('button, form, a');
                        buttons.forEach(b => b.setAttribute('disabled', 'disabled'));
                        container.appendChild(gridClone);
                    }
                });

            setTimeout(() => {
                document.getElementById('createBackdrop').classList.add('open');
                document.getElementById('createDrawer').classList.add('open');
            }, 50);
        });
    </script>
}
