@model TeacherDeactivateViewModel
@{
    Layout = "_LayoutCoordinator";
}

<div class="col-12 col-md-6 offset-md-3 ">
    <div class="card">
        <div class="card-header bg-danger text-light">
            <h4 class="text-center">
                Esta seguro que desea cambiar el estado del docente: @Model.Name?
            </h4>
        </div>
        <div class="card-body">
            <form asp-controller="Teacher" asp-action="Deactive" method="POST">
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-center">
                    <button type="submit" class="btn btn-danger me-2"><i class="bi bi-trash"></i> Deactivate</button>
                    <a asp-controller="Teacher" asp-action="Index" class="btn btn-outline-warning"><i class="bi bi-arrow-left-short"></i> Volver al listado</a>
                </div>
            </form>
        </div>
    </div>
</div>
