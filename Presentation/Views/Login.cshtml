@page
@model Presentation.Pages.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Ingresar al Portal";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Académico</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --color-bg-page: #F8F9FA;
            --color-primary: #0F1B32;
            --color-primary-overlay: rgba(15, 27, 50, 0.82);
            --color-accent: #D97706;
            --color-text-dark: #0F1B32;
            --color-text-muted: #64748B;
            --color-text-label: #475569;
            --color-text-placeholder: #94A3B8;
            --color-text-footer: #7E92A2;
            --color-input-bg: #F8FAFC;
            --color-input-border: #E2E8F0;
            --color-input-focus: #3B82F6;
            --color-error-bg: #FEF2F2;
            --color-error-text: #DC2626;
            --color-error-border: #FCA5A5;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--color-bg-page);
            color: var(--color-text-dark);
            height: 100vh;
            display: flex;
            overflow: hidden;
        }

        .login-container {
            display: flex;
            width: 100%;
            height: 100vh;
        }

        .branding-panel {
            flex: 1.2;
            position: relative;
            background-image: url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?q=80&w=1280&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 80px;
            color: #ffffff;
        }

        .branding-panel::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(11, 15, 25, 0.85);
            z-index: 1;
        }

        .branding-content-top {
            position: relative;
            z-index: 2;
            margin-top: 20px;
        }

        .gold-line {
            width: 180px;
            height: 3px;
            background-color: var(--color-accent);
            margin-bottom: 24px;
            border-radius: 2px;
        }

        .branding-title {
            font-size: 44px;
            font-weight: 700;
            line-height: 1.2;
            max-width: 600px;
            letter-spacing: -0.02em;
        }

        .branding-content-bottom {
            position: relative;
            z-index: 2;
            max-width: 550px;
            line-height: 1.6;
        }

        .branding-quote {
            font-size: 16px;
            font-weight: 400;
            color: #D1D5DB;
            font-style: italic;
        }

        .branding-author {
            margin-top: 8px;
            font-size: 14px;
            font-weight: 500;
            color: #9CA3AF;
        }

        .form-panel {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
            background-color: var(--color-bg-page);
        }

        .login-card {
            width: 100%;
            max-width: 466px;
            background: #ffffff;
            border-radius: 15px;
            padding: 48px;
            box-shadow: 0 12px 28px rgba(15, 27, 50, 0.08);
            border: 1px solid rgba(226, 232, 240, 0.8);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .login-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 16px 36px rgba(15, 27, 50, 0.12);
        }

        .card-header-title {
            font-size: 22px;
            font-weight: 700;
            color: var(--color-primary);
            margin-bottom: 8px;
            letter-spacing: -0.01em;
        }

        .card-header-subtitle {
            font-size: 13px;
            color: var(--color-text-muted);
            margin-bottom: 32px;
            line-height: 1.5;
        }

        .form-group {
            margin-bottom: 22px;
            display: flex;
            flex-direction: column;
        }

        .form-label {
            font-size: 12px;
            font-weight: 600;
            color: var(--color-text-label);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .input-wrapper {
            position: relative;
        }

        .form-input {
            width: 100%;
            height: 44px;
            padding: 0 16px;
            background-color: var(--color-input-bg);
            border: 1px solid var(--color-input-border);
            border-radius: 8px;
            font-size: 13px;
            color: var(--color-text-dark);
            outline: none;
            transition: all 0.2s ease;
        }

        .form-input::placeholder {
            color: var(--color-text-placeholder);
        }

        .form-input:focus {
            border-color: var(--color-input-focus);
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }

        .forgot-password-container {
            display: flex;
            justify-content: flex-end;
            margin-top: -10px;
            margin-bottom: 24px;
        }

        .forgot-password-link {
            font-size: 12px;
            font-weight: 600;
            color: var(--color-accent);
            text-decoration: none;
            transition: color 0.2s ease;
        }

        .forgot-password-link:hover {
            color: #b45309;
            text-decoration: underline;
        }

        .btn-submit {
            width: 100%;
            height: 46px;
            background-color: var(--color-primary);
            color: #ffffff;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            letter-spacing: 0.02em;
        }

        .btn-submit:hover {
            background-color: #1a2e50;
            box-shadow: 0 4px 12px rgba(15, 27, 50, 0.2);
        }

        .btn-submit:active {
            transform: scale(0.98);
        }

        .card-footer-text {
            margin-top: 32px;
            font-size: 11px;
            color: var(--color-text-footer);
            line-height: 1.5;
            text-align: center;
        }

        .alert-error {
            background-color: var(--color-error-bg);
            border: 1px solid var(--color-error-border);
            color: var(--color-error-text);
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 24px;
            line-height: 1.4;
        }

        .field-validation-error {
            color: var(--color-error-text);
            font-size: 11px;
            margin-top: 4px;
            font-weight: 500;
        }

        @@media (max-width: 1024px) {
            .branding-panel {
                display: none;
            }
            .form-panel {
                flex: 1;
                padding: 20px;
            }
            .login-card {
                padding: 32px;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="branding-panel">
            <div class="branding-content-top">
                <div class="gold-line"></div>
                <h1 class="branding-title">Cultivando el<br>saber y la virtud.</h1>
            </div>
            <div class="branding-content-bottom">
                <p class="branding-quote">"La educación no es preparación para la vida; la educación es la vida misma."</p>
                <p class="branding-author">— John Dewey</p>
            </div>
        </div>

        <div class="form-panel">
            <div class="login-card">
                <h2 class="card-header-title">Ingresar al Portal</h2>
                <p class="card-header-subtitle">Acceso seguro para la comunidad coordinativa y docente.</p>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert-error">
                        @Model.ErrorMessage
                    </div>
                }

                @if (!ViewData.ModelState.IsValid && string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert-error">
                        Por favor, corrija los errores en el formulario para continuar.
                    </div>
                }

                <form method="post">
                    <input type="hidden" asp-for="ReturnUrl" />

                    <div class="form-group">
                        <label asp-for="Email" class="form-label">Correo electrónico</label>
                        <div class="input-wrapper">
                            <input asp-for="Email" class="form-input" placeholder="ej. mat.10283@docente.edu.do" autocomplete="username" required />
                        </div>
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Password" class="form-label">Contraseña</label>
                        <div class="input-wrapper">
                            <input asp-for="Password" class="form-input" type="password" placeholder="••••••••••••" autocomplete="current-password" required />
                        </div>
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>

                    <div class="forgot-password-container">
                        <a href="/ForgotPassword" class="forgot-password-link">¿Olvidaste tu contraseña?</a>
                    </div>

                    <button type="submit" class="btn-submit">Ingresar</button>
                </form>

                <p class="card-footer-text">
                    &copy; Si aún no cuentas con tus credenciales de acceso, favor de solicitarlas en el Departamento de Administración.
                </p>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
