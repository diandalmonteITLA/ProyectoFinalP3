@model App.Core.Application.DTOs.Students.UpdateStudentDto
@{
    Layout = "_LayoutCoordinator";
    ViewData["Title"] = "Editar Estudiante";
    ViewData["BannerDescription"] = "Listado general de alumnos admitidos en este ciclo académico.";
}

<div id="background-grid-container" style="pointer-events: none; opacity: 0.6; filter: grayscale(20%);"></div>

<a asp-controller="Student" asp-action="Index" class="drawer-backdrop" id="createBackdrop" onclick="closeCreateDrawer(event)"></a>

<div class="drawer-form-panel" id="createDrawer">
    <div class="drawer-header">
        <h2 class="drawer-title" id="drawerTitle">Editar Estudiante</h2>
    </div>

    <form asp-controller="Student" asp-action="Edit" method="post" id="drawerForm" style="display: flex; flex-direction: column; height: 100%;">
        <input type="hidden" asp-for="Id" id="field-id" />

        <div class="drawer-body">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="text-danger" style="margin-bottom: 20px; font-size: 13px; font-weight: 500;"></div>
            }

            <div class="row" style="margin-bottom: 20px;">
                <div class="col drawer-field-group">
                    <label class="drawer-label">Nombre</label>
                    <input asp-for="Name" class="drawer-input" id="field-name" placeholder="ej. Alejandro" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col drawer-field-group">
                    <label class="drawer-label">Apellido</label>
                    <input asp-for="LastName" class="drawer-input" id="field-lastname" placeholder="ej. Ortiz" required />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>
            <div class="drawer-field-group" style="margin-bottom: 20px;">
                <label class="drawer-label">Grado</label>
                <select asp-for="GradeId" class="drawer-input" id="field-grade" style="padding: 0 12px;" data-selected-value="@Model.GradeId" required>
                    <option value="">Seleccionar grado...</option>
                </select>
                <span asp-validation-for="GradeId" class="text-danger"></span>
            </div>
            
            <div class="drawer-field-group" style="margin-top: 10px; position: relative;">
                <label class="drawer-label" style="color: var(--color-accent); font-weight: 600; font-size: 12px;">Seleccionar Acudiente</label>
                <p style="font-size: 11px; color: var(--color-text-muted); margin-bottom: 12px; line-height: 1.4;">Busque y seleccione el acudiente registrado en el sistema que estará a cargo de este estudiante.</p>
                <div style="position: relative;">
                    <input type="text" class="drawer-input" id="drawerGuardianSearchInput" placeholder="🔍 Buscar acudiente..." oninput="filterDrawerGuardians()" onfocus="showDrawerGuardiansList()" required />
                    
                    <div id="drawerGuardiansAutocompleteList" style="position: absolute; bottom: 100%; left: 0; width: 100%; max-height: 150px; overflow-y: auto; border: 1px solid var(--color-border); border-radius: 8px; background: #ffffff; display: none; z-index: 1080; box-shadow: 0 4px 12px rgba(15,23,42,0.15); margin-bottom: 4px;">
                    </div>
                </div>
                <span asp-validation-for="GuardianIds" class="text-danger"></span>
            </div>

            @{
                var selectedIdsJson = System.Text.Json.JsonSerializer.Serialize(Model.GuardianIds);
            }
            <select asp-for="GuardianIds" id="field-guardian" style="display:none;" multiple="multiple" data-selected-ids="@selectedIdsJson" required>
            </select>
        </div>

        <div class="drawer-footer">
            <a asp-controller="Student" asp-action="Index" class="btn-drawer-cancel" onclick="closeCreateDrawer(event)" style="text-decoration: none; text-align: center; display: inline-flex; align-items: center; justify-content: center;">Cancelar</a>
            <button type="submit" class="btn-drawer-submit" id="btnDrawerSubmit">Guardar Estudiante</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeCreateDrawer(event) {
            event.preventDefault();
            const url = event.currentTarget.getAttribute('href') || '/Student';
            document.getElementById('createBackdrop').classList.remove('open');
            document.getElementById('createDrawer').classList.remove('open');
            setTimeout(() => {
                window.location.href = url;
            }, 300);
        }

        function showDrawerGuardiansList() {
            document.getElementById('drawerGuardiansAutocompleteList').style.display = 'block';
        }

        function filterDrawerGuardians() {
            const query = document.getElementById('drawerGuardianSearchInput').value.toLowerCase().trim();
            const list = document.getElementById('drawerGuardiansAutocompleteList');
            const items = list.getElementsByClassName('autocomplete-item-drawer');
            let hasAny = false;
            
            for (let item of items) {
                const name = item.getAttribute('data-name');
                if (name.includes(query)) {
                    item.style.display = '';
                    hasAny = true;
                } else {
                    item.style.display = 'none';
                }
            }
            
            list.style.display = hasAny ? 'block' : 'none';
        }

        function selectDrawerExistingGuardian(id, fullName) {
            document.getElementById('drawerGuardianSearchInput').value = fullName;
            
            const select = document.getElementById('field-guardian');
            for (let option of select.options) {
                if (option.value === id) {
                    option.selected = true;
                } else {
                    option.selected = false;
                }
            }
            
            document.getElementById('drawerGuardiansAutocompleteList').style.display = 'none';
        }

        document.addEventListener('click', (e) => {
            const container = document.getElementById('drawerGuardiansAutocompleteList');
            const input = document.getElementById('drawerGuardianSearchInput');
            if (container && e.target !== container && e.target !== input && !container.contains(e.target)) {
                container.style.display = 'none';
            }
        });

        document.addEventListener('DOMContentLoaded', () => {
            fetch('/Student/Create')
                .then(response => response.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    
                    const sourceGradeSelect = doc.getElementById('field-grade');
                    const targetGradeSelect = document.getElementById('field-grade');
                    if (sourceGradeSelect && targetGradeSelect) {
                        const preselectedValue = targetGradeSelect.getAttribute('data-selected-value');
                        targetGradeSelect.innerHTML = sourceGradeSelect.innerHTML;
                        if (preselectedValue) {
                            targetGradeSelect.value = preselectedValue;
                        }
                    }
                    
                    const sourceGuardianSelect = doc.getElementById('field-guardian');
                    const targetGuardianSelect = document.getElementById('field-guardian');
                    const autocompleteList = document.getElementById('drawerGuardiansAutocompleteList');
                    
                    if (sourceGuardianSelect && targetGuardianSelect) {
                        targetGuardianSelect.innerHTML = sourceGuardianSelect.innerHTML;
                        
                        let selectedIds = [];
                        try {
                            const rawIds = targetGuardianSelect.getAttribute('data-selected-ids');
                            selectedIds = JSON.parse(rawIds || '[]');
                        } catch (e) {
                            selectedIds = [];
                        }
                        
                        const normalizedSelectedIds = Array.isArray(selectedIds) 
                            ? selectedIds.map(id => String(id).toLowerCase()) 
                            : [];
                            
                        for (let option of targetGuardianSelect.options) {
                            if (normalizedSelectedIds.includes(String(option.value).toLowerCase())) {
                                option.selected = true;
                                document.getElementById('drawerGuardianSearchInput').value = option.text;
                            }
                        }
                    }
                    
                    const sourceAutocompleteList = doc.getElementById('drawerGuardiansAutocompleteList');
                    if (sourceAutocompleteList && autocompleteList) {
                        autocompleteList.innerHTML = sourceAutocompleteList.innerHTML;
                    }
                });

            fetch('/Student')
                .then(response => response.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const grid = doc.querySelector('.cards-grid');
                    const controls = doc.querySelector('.workspace-controls');
                    const container = document.getElementById('background-grid-container');
                    
                    if (controls) {
                        const controlsClone = controls.cloneNode(true);
                        const inputs = controlsClone.querySelectorAll('input, select, button, a');
                        inputs.forEach(i => i.setAttribute('disabled', 'disabled'));
                        container.appendChild(controlsClone);
                    }
                    if (grid) {
                        const gridClone = grid.cloneNode(true);
                        const buttons = gridClone.querySelectorAll('button, form, a');
                        buttons.forEach(b => b.setAttribute('disabled', 'disabled'));
                        container.appendChild(gridClone);
                    }
                });

            setTimeout(() => {
                document.getElementById('createBackdrop').classList.add('open');
                document.getElementById('createDrawer').classList.add('open');
            }, 50);
        });
    </script>
}
