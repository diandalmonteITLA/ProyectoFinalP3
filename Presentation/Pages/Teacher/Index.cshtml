@model List<TeacherViewModel>;
@{
    ViewData["Title"] = "Géstion Profesores";
    Layout = "_LayoutCoordinator";
}

<button class="btn-register-docente" onclick="openCreateDrawer()">
    + Registrar Docente
</button>

<section class="table-card">
    <table class="teachers-table">
        <thead>
            <tr>
                <th>Profesor</th>
                <th>Correo Electrónico</th>
                <th>Número Telefónico</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" style="text-align: center; color: var(--color-text-muted); padding: 40px;">
                        No se encontraron profesores registrados con ese criterio.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var teacher in Model)
                {
                    var initials = (teacher.Name.Length > 0 ? teacher.Name[0].ToString() : "") + (teacher.LastName.Length > 0 ? teacher.LastName[0].ToString() : "");
                    <tr>
                        <td>
                            <div class="profile-cell">
                                <span class="teacher-fullname">@teacher.Name @teacher.LastName</span>
                            </div>
                        </td>
                        <td>@teacher.Email</td>
                        <td>@teacher.Phone</td>
                        <td>
                            <div class="action-group">
                                <a asp-controller="Teacher" asp-action="Edit" asp-route-id="@teacher.Id"
                                   class="btn-action-icon drawer-trigger" title="Editar">
                                    <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                </a>

                                <a asp-controller="Teacher" asp-action="Deactivate" asp-route-id="@teacher.Id"
                                   class="btn-action-icon btn-delete drawer-trigger" title="Desactivar">
                                    <svg viewBox="0 0 24 24">
                                        <polyline points="3 6 5 6 21 6"></polyline>
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                        <line x1="10" y1="11" x2="10" y2="17"></line>
                                        <line x1="14" y1="11" x2="14" y2="17"></line>
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</section>