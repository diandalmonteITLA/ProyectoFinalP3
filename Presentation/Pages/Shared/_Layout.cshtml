<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Instituto qsy</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        :root {
            --color-bg-page: #F8FAFC;
            --color-sidebar-bg: #0B0F19;
            --color-accent: #D97706;
            --color-text-dark: #0F172A;
            --color-text-muted: #94A3B8;
            --color-text-label: #475569;
            --color-border: #E2E8F0;
            --color-card-bg: #FFFFFF;
            --color-input-bg: #F8FAFC;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--color-bg-page);
            color: var(--color-text-dark);
            height: 100vh;
            display: flex;
            overflow: hidden;
        }

        .dashboard-container {
            display: flex;
            width: 100%;
            height: 100vh;
        }

        .sidebar {
            width: 260px;
            background-color: var(--color-sidebar-bg);
            height: 100%;
            display: flex;
            flex-direction: column;
            padding: 36px 0;
            flex-shrink: 0;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            padding: 0 24px;
            margin-bottom: 48px;
        }

        .brand-emblem {
            width: 24px;
            height: 24px;
            background-color: var(--color-accent);
            border-radius: 4px;
            margin-right: 12px;
            flex-shrink: 0;
        }

        .brand-text {
            font-size: 16px;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: -0.01em;
        }

        .sidebar-menu {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 0 16px;
        }

        .menu-link {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            color: #94A3B8;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            border-radius: 8px;
            transition: all 0.2s ease;
        }

            .menu-link:hover {
                color: #ffffff;
                background-color: rgba(255, 255, 255, 0.03);
            }

            .menu-link svg {
                margin-right: 12px;
                width: 18px;
                height: 18px;
                stroke: currentColor;
                stroke-width: 2;
                fill: none;
            }

        .menu-item.active .menu-link {
            color: #ffffff;
            background-color: var(--color-accent);
            font-weight: 700;
        }

        .main-workspace {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            padding: 30px;
        }

        .academic-banner {
            width: 100%;
            height: 160px;
            border-radius: 16px;
            position: relative;
            background-image: url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?q=80&w=1280&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 30px 40px;
            color: #ffffff;
            margin-bottom: 30px;
            box-shadow: 0 4px 20px rgba(15, 23, 42, 0.05);
            overflow: hidden;
            border: 1px solid rgba(226, 232, 240, 0.8);
        }

            .academic-banner::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-color: rgba(15, 23, 42, 0.85);
                z-index: 1;
            }

        .banner-content {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            justify-content: center;
            height: 100%;
        }

        .banner-accent-bar {
            width: 80px;
            height: 4px;
            background-color: var(--color-accent);
            margin-bottom: 12px;
            border-radius: 2px;
        }

        .banner-subtitle {
            font-size: 11px;
            font-weight: 600;
            color: var(--color-accent);
            letter-spacing: 0.08em;
            margin-bottom: 6px;
        }

        .banner-title {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 6px;
            letter-spacing: -0.02em;
            color: #ffffff;
        }

        .banner-description {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.7);
        }

        .user-floating-profile {
            position: relative;
            z-index: 2;
            width: 220px;
            height: 50px;
            background-color: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            display: flex;
            align-items: center;
            padding: 0 12px;
            backdrop-filter: blur(4px);
        }

        .profile-avatar {
            width: 32px;
            height: 32px;
            background-color: var(--color-accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            font-size: 11px;
            font-weight: 700;
            margin-right: 10px;
            flex-shrink: 0;
        }

        .profile-meta {
            display: flex;
            flex-direction: column;
        }

        .profile-username {
            font-size: 11px;
            font-weight: 600;
            color: #ffffff;
        }

        .profile-userrole {
            font-size: 9px;
            color: var(--color-accent);
            margin-top: 1px;
            font-weight: 500;
        }

        .profile-logout-btn {
            margin-left: auto;
            font-size: 12px;
            color: rgba(255, 255, 255, 0.6);
            text-decoration: none;
            transition: color 0.2s ease;
        }

            .profile-logout-btn:hover {
                color: #EF4444;
            }
        .workspace-controls {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
        }

        .search-container {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .table-search-input {
            width: 320px;
            height: 38px;
            background-color: #ffffff;
            border: 1px solid var(--color-border);
            border-radius: 8px;
            padding: 0 16px;
            font-size: 12px;
            outline: none;
            transition: all 0.2s ease;
        }

        .btn-filter {
            height: 38px;
            background-color: #ffffff;
            border: 1px solid var(--color-border);
            border-radius: 8px;
            padding: 0 16px;
            font-size: 12px;
            font-weight: 600;
            color: var(--color-text-dark);
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-register-docente {
            height: 38px;
            background-color: #0B0F19;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            padding: 0 24px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .table-card {
            background-color: #ffffff;
            border: 1px solid var(--color-border);
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 24px;
        }

        .teachers-table {
            width: 100%;
            border-collapse: collapse;
        }

            .teachers-table th {
                padding: 20px 24px;
                font-size: 11px;
                font-weight: 600;
                color: var(--color-text-label);
                border-bottom: 1px solid var(--color-border);
                text-transform: uppercase;
                background-color: #FAFBFD;
            }

            .teachers-table td {
                padding: 18px 24px;
                font-size: 13px;
                border-bottom: 1px solid var(--color-border);
                vertical-align: middle;
            }

        .profile-cell {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .avatar-mini {
            width: 32px;
            height: 32px;
            background-color: #F1F5F9;
            border: 1px solid var(--color-border);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 600;
        }

        .action-group {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .btn-action-icon {
            background: none;
            border: none;
            padding: 4px;
            cursor: pointer;
            color: #94A3B8;
            display: inline-flex;
        }

            .btn-action-icon:hover {
                color: #0F172A;
            }

            .btn-action-icon.btn-delete:hover {
                color: #EF4444;
            }

            .btn-action-icon svg {
                width: 16px;
                height: 16px;
                stroke: currentColor;
                stroke-width: 2;
                fill: none;
            }

        .crud-card {
            background: white;
            padding: 30px;
            border-radius: 16px;
            border: 1px solid var(--color-border);
            max-width: 600px;
        }

        .field-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 20px;
        }

        .form-label {
            font-size: 12px;
            font-weight: 600;
            color: var(--color-text-label);
        }

        .form-input {
            width: 100%;
            height: 42px;
            background-color: var(--color-input-bg);
            border: 1px solid var(--color-border);
            border-radius: 8px;
            padding: 0 16px;
            font-size: 13px;
            outline: none;
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <div class="brand-emblem"></div>
                <span class="brand-text">Instituto tal</span>
            </div>
            <ul class="sidebar-menu">
                <li class="menu-item active">
                    <a href="/Teacher" class="menu-link">
                        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
                        <span>Docentes</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/Students" class="menu-link">
                        <svg viewBox="0 0 24 24"><path d="M22 10l10-5 10 5-10 5z"></path></svg>
                        <span>Estudiantes</span>
                    </a>
                </li>
            </ul>
        </aside>

        <main class="main-workspace">
            <section class="academic-banner">
                <div class="banner-content">
                    <div class="banner-accent-bar"></div>
                    <span class="banner-subtitle">• PORTAL DE GESTIÓN</span>
                    <h1 class="banner-title">@ViewData["Title"]</h1>
                    <p class="banner-description">Panel administrativo de la institución.</p>
                </div>
                <div class="user-floating-profile">
                    <div class="profile-avatar">CB</div>
                    <div class="profile-meta">
                        <span class="profile-username">@User.Identity?.Name</span>
                        <span class="profile-userrole">Coordinadora General</span>
                    </div>
                </div>
            </section>

            @RenderBody()
        </main>
    </div>
</body>
</html>